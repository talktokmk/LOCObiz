{
  "manifest_version": 3,
  "name": "ADZBE Scraper",
  "version": "1.0.0",
  "description": "Scrape Google Maps business data directly to ADZBE admin panel. Free, no API key needed.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://adzbe.cloud/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ADZBE Scraper"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*", "https://maps.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
